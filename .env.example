# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=distributed_file_storage
DB_USER=dfs_user
DB_PASSWORD=dfs_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# HSM Configuration
HSM_URL=http://localhost:3001

# Storage Configuration
CHUNK_SIZE=8388608
REPLICATION_FACTOR=3
VIRTUAL_NODES_PER_PHYSICAL=150

# CDN Configuration
CDN_CACHE_TTL=86400
CDN_EDGE_LOCATIONS=us-east-1,us-west-1,eu-west-1

# Upload Configuration
MAX_PARALLEL_CHUNKS=10
UPLOAD_SESSION_EXPIRY_DAYS=7

# Version Configuration
DEFAULT_RETENTION_DAYS=30

# Security Configuration
JWT_SECRET=your-secret-key-here
JWT_EXPIRY=3600

# Performance Configuration
MAX_UPLOAD_SPEED_MBPS=100
MAX_DOWNLOAD_SPEED_MBPS=100
